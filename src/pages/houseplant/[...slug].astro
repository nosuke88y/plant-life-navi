---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { extractFaq } from '../../utils/extractFaq';

export async function getStaticPaths() {
  const posts = await getCollection('houseplant');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, allPosts: posts } }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const otherPosts = allPosts.filter((p) => p.id !== post.id);
const shuffled = otherPosts.sort(() => Math.random() - 0.5);
const relatedPosts = shuffled.slice(0, 3).map((p) => ({
  title: p.data.title, description: p.data.description, date: p.data.date, tags: p.data.tags, href: `/houseplant/${p.id}/`,
}));

// プリマオンラインを追加する記事
const primaArticles = [
  'houseplant-dying-causes',
  'pachira-care-guide',
  'evergreen-ash-care-guide',
  'adiantum-care-guide',
  'sansevieria-care-guide',
  'houseplant-yellow-leaves',
  'houseplant-brown-leaves',
  'houseplant-winter-care',
];
const affiliateType = primaArticles.includes(post.id) ? 'houseplant-prima' : 'houseplant';

const faqItems = extractFaq(post.body ?? '');
---

<ArticleLayout title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} category="houseplant" headings={headings} relatedPosts={relatedPosts} affiliateType={affiliateType} faqItems={faqItems}>
  <Content />
</ArticleLayout>
