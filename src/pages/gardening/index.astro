---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('gardening')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const themes = [
  { label: 'すべて', key: 'all' },
  { label: '花・植栽', key: 'flower' },
  { label: '土・肥料', key: 'soil' },
  { label: '道具・DIY', key: 'tools' },
];

function getThemes(tags: string[]): string[] {
  const joined = tags.join(' ');
  const r: string[] = [];
  if (/花|植栽|種まき|苗|植え付け/.test(joined)) r.push('flower');
  if (/土|肥料|堆肥|培養土/.test(joined)) r.push('soil');
  if (/道具|DIY|プランター|鉢/.test(joined)) r.push('tools');
  return r;
}
---

<BaseLayout title="ガーデニングの記事一覧" description="花壇・プランター・土づくりに関するガーデニング記事をまとめています。">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8 pb-6 border-b border-[var(--color-rule)]">
      <h1 class="text-2xl md:text-3xl font-medium text-[var(--color-ink)] tracking-tight">ガーデニングの記事一覧</h1>
      <p class="text-sm text-[var(--color-ink-mute)] mt-2 tabular-nums">全{posts.length}件</p>
    </header>

    <div class="mb-4 flex flex-wrap gap-x-5 gap-y-2" id="theme-filter">
      {themes.map((theme, i) => (
        <button class={`theme-btn text-sm transition-colors ${i === 0 ? 'active text-[var(--color-accent-700)] font-medium' : 'text-[var(--color-ink-mute)] hover:text-[var(--color-ink)]'}`} data-theme={theme.key}>{theme.label}</button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-[var(--color-ink-mute)] text-center py-20">記事はまだありません。</p>
    ) : (
      <div class="border-t border-[var(--color-rule)]">
        {posts.map((post) => (
          <ArticleCard title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} href={`/gardening/${post.id}/`} data-themes={getThemes(post.data.tags).join(',')} />
        ))}
      </div>
    )}
    <p id="no-results" class="text-[var(--color-ink-mute)] text-center py-10 hidden">該当する記事がありません。</p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('no-results');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const theme = btn.dataset.theme;
      buttons.forEach((b) => { b.classList.remove('active','text-[var(--color-accent-700)]','font-medium'); b.classList.add('text-[var(--color-ink-mute)]'); });
      btn.classList.add('active','text-[var(--color-accent-700)]','font-medium'); btn.classList.remove('text-[var(--color-ink-mute)]');
      let v = 0;
      cards.forEach((c) => { const t = (c.dataset.themes||'').split(','); const s = theme==='all'||t.includes(theme!); c.style.display = s?'':'none'; if(s) v++; });
      if (noResults) noResults.classList.toggle('hidden', v > 0);
    });
  });
</script>
