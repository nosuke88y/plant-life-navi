---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { extractFaq } from '../../utils/extractFaq';

export async function getStaticPaths() {
  const posts = await getCollection('gardening');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, allPosts: posts } }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const otherPosts = allPosts.filter((p) => p.id !== post.id);
const shuffled = otherPosts.sort(() => Math.random() - 0.5);
const relatedPosts = shuffled.slice(0, 3).map((p) => ({
  title: p.data.title, description: p.data.description, date: p.data.date, tags: p.data.tags, href: `/gardening/${p.id}/`,
}));

// 記事別アフィリエイトタイプ
const flowerFullArticles = ['summer-flowers-guide', 'winter-flowers-guide', 'autumn-flowers-guide'];
const flowerArticles = ['planter-gardening-guide'];
const soilArticles = ['gardening-soil-guide', 'gardening-fertilizer-guide', 'organic-fertilizer-guide', 'soil-making-basics'];

let affiliateType = 'gardening-general';
if (flowerFullArticles.includes(post.id)) affiliateType = 'gardening-flowers-full';
else if (flowerArticles.includes(post.id)) affiliateType = 'gardening-flowers';
else if (soilArticles.includes(post.id)) affiliateType = 'gardening-soil';

const faqItems = extractFaq(post.body ?? '');
---

<ArticleLayout title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} category="gardening" headings={headings} relatedPosts={relatedPosts} affiliateType={affiliateType} faqItems={faqItems}>
  <Content />
</ArticleLayout>
