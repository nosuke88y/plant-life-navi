---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const houseplantPosts = await getCollection('houseplant');
const succulentPosts = await getCollection('succulent');
const gardeningPosts = await getCollection('gardening');

const categoryMap = new Map<string, string>();
houseplantPosts.forEach(p => categoryMap.set(p.id, 'houseplant'));
succulentPosts.forEach(p => categoryMap.set(p.id, 'succulent'));
gardeningPosts.forEach(p => categoryMap.set(p.id, 'gardening'));

const allPosts = [...houseplantPosts, ...succulentPosts, ...gardeningPosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const recommendedPosts = allPosts.slice(0, 6);

const categories = [
  { href: '/houseplant/', label: '観葉植物', count: houseplantPosts.length, description: '育て方・置き場所・水やりのコツ' },
  { href: '/succulent/', label: '多肉植物', count: succulentPosts.length, description: '種類・増やし方・季節管理' },
  { href: '/gardening/', label: 'ガーデニング', count: gardeningPosts.length, description: '花壇・プランター・土づくり' },
];

const siteUrl = 'https://plant-life-navi.com';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Plant Life Navi',
  alternateName: 'プラントライフナビ',
  url: `${siteUrl}/`,
  inLanguage: 'ja',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Plant Life Navi',
  url: `${siteUrl}/`,
  logo: `${siteUrl}/favicon.ico`,
  sameAs: ['https://x.com/plant_navi_jp'],
};

const jsonLd = [websiteSchema, organizationSchema];
---

<BaseLayout title="Plant Life Navi" jsonLd={jsonLd}>
  <section class="max-w-3xl mx-auto px-4 pt-16 pb-12 border-b border-[var(--color-rule)]">
    <p class="text-xs text-[var(--color-ink-mute)] tracking-[0.3em] uppercase mb-5">Plant Information</p>
    <h1 class="text-3xl md:text-4xl font-medium text-[var(--color-ink)] leading-tight tracking-tight mb-5">
      植物とともに、豊かな暮らしを。
    </h1>
    <p class="text-sm md:text-base text-[var(--color-ink-sub)] leading-relaxed max-w-xl">
      観葉植物・多肉植物・ガーデニングに関する信頼できる情報を、わかりやすく解説します。
    </p>
  </section>

  <div class="max-w-3xl mx-auto px-4 py-12">
    <section class="mb-16">
      <h2 class="text-xs text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Categories</h2>
      <ul class="border-t border-[var(--color-rule)]">
        {categories.map((cat) => (
          <li>
            <a href={cat.href} class="group flex items-baseline justify-between gap-6 py-4 border-b border-[var(--color-rule)] transition-colors hover:bg-neutral-50 px-2 -mx-2">
              <div class="min-w-0">
                <p class="text-base font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent-700)] transition-colors">{cat.label}</p>
                <p class="text-sm text-[var(--color-ink-mute)] mt-0.5">{cat.description}</p>
              </div>
              <span class="shrink-0 text-xs text-[var(--color-ink-mute)] tabular-nums">{cat.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="text-xs text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Featured</h2>
      <div class="border-t border-[var(--color-rule)]">
        {recommendedPosts.map((post) => {
          const category = categoryMap.get(post.id) ?? 'houseplant';
          return (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              href={`/${category}/${post.id}/`}
            />
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>
