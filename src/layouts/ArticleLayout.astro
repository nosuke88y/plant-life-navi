---
import BaseLayout from './BaseLayout.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Heading { depth: number; slug: string; text: string; }
interface RelatedPost { title: string; description: string; date: Date; tags: string[]; href: string; }

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: 'houseplant' | 'succulent' | 'gardening';
  headings?: Heading[];
  relatedPosts?: RelatedPost[];
  affiliateType?: string;
}

const { title, description, date, tags, category, headings = [], relatedPosts = [], affiliateType = 'houseplant' } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryLabelMap = {
  'houseplant': '🌿 観葉植物',
  'succulent': '🪴 多肉植物',
  'gardening': '🌻 ガーデニング',
};
const categoryLabel = categoryLabelMap[category];
const categoryHref = `/${category}/`;

const siteUrl = 'https://plant-life-navi.com';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;

// 構造化データ用のカテゴリ名（emoji無し）
const categoryNameMap = {
  'houseplant': '観葉植物',
  'succulent': '多肉植物',
  'gardening': 'ガーデニング',
};
const categoryName = categoryNameMap[category];

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Plant Life Navi編集部',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Plant Life Navi',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.ico`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  image: `${siteUrl}/og-image.png`,
  keywords: tags.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: categoryName, item: `${siteUrl}${categoryHref}` },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};

const jsonLd = [blogPostingSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="lg:flex lg:gap-10">

      <!-- メインコンテンツ -->
      <div class="lg:flex-1 lg:min-w-0 max-w-3xl">

        <!-- パンくずリスト -->
        <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
          <a href="/" class="hover:text-emerald-600 transition-colors">ホーム</a>
          <span>/</span>
          <a href={categoryHref} class="hover:text-emerald-600 transition-colors">{categoryLabel}</a>
          <span>/</span>
          <span class="text-gray-600 truncate">{title}</span>
        </nav>

        <!-- タグ -->
        <div class="flex flex-wrap gap-1 mb-4">
          {tags.map((tag) => (
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">#{tag}</span>
          ))}
        </div>

        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-3">{title}</h1>

        <time datetime={date.toISOString()} class="text-sm text-gray-400 block mb-8">{formattedDate}</time>

        <TableOfContents headings={headings} />

        <!-- アフィリエイトボックス（目次直後） -->
        <AffiliateBox type={affiliateType} />

        <!-- 記事本文 -->
        <article class="
          prose prose-gray max-w-none prose-base leading-relaxed
          prose-p:text-gray-700 prose-p:leading-[1.9] prose-p:mb-6
          prose-h2:text-2xl prose-h2:font-bold prose-h2:text-gray-900 prose-h2:mt-12 prose-h2:mb-5 prose-h2:pb-2 prose-h2:border-b-2 prose-h2:border-emerald-200
          prose-h3:text-xl prose-h3:font-bold prose-h3:text-gray-800 prose-h3:mt-8 prose-h3:mb-3
          prose-ul:my-5 prose-ul:pl-2 prose-ol:my-5 prose-ol:pl-2
          prose-li:text-gray-700 prose-li:leading-[1.8] prose-li:my-1
          prose-table:text-sm prose-th:bg-gray-100 prose-th:text-gray-700 prose-td:text-gray-600
          prose-strong:text-gray-900 prose-strong:font-bold
          prose-a:text-emerald-700 prose-a:underline prose-a:underline-offset-2
        ">
          <slot />
        </article>

        <!-- アフィリエイトボックス（末尾） -->
        <AffiliateBox type={affiliateType} />

        <ShareButtons title={title} url={pageUrl} />

        <div class="lg:hidden">
          <RelatedArticles posts={relatedPosts} />
        </div>

        <div class="mt-12 pt-8 border-t border-gray-200">
          <a href={categoryHref} class="inline-flex items-center gap-2 text-sm text-emerald-700 hover:text-emerald-600 font-medium transition-colors">
            ← {categoryLabel}の記事一覧に戻る
          </a>
        </div>
      </div>

      <!-- PC用サイドバー -->
      {relatedPosts.length > 0 && (
        <aside class="hidden lg:block lg:w-72 lg:shrink-0">
          <div class="sticky top-20">
            <p class="text-sm font-bold text-gray-700 mb-4">📖 関連記事</p>
            <div class="flex flex-col gap-3">
              {relatedPosts.map((post) => (
                <a href={post.href} class="group block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-emerald-300 transition-all">
                  <div class="flex flex-wrap gap-1 mb-1.5">
                    {post.tags.slice(0, 2).map((tag) => (
                      <span class="text-xs bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded-full">#{tag}</span>
                    ))}
                  </div>
                  <p class="text-sm font-bold text-gray-900 group-hover:text-emerald-700 transition-colors leading-snug line-clamp-3">{post.title}</p>
                </a>
              ))}
            </div>
            <div class="mt-6 pt-6 border-t border-gray-200">
              <p class="text-sm font-bold text-gray-700 mb-3">カテゴリ</p>
              <div class="flex flex-col gap-2 text-sm">
                <a href="/houseplant/" class="text-gray-600 hover:text-emerald-700 transition-colors">🌿 観葉植物</a>
                <a href="/succulent/" class="text-gray-600 hover:text-emerald-700 transition-colors">🪴 多肉植物</a>
                <a href="/gardening/" class="text-gray-600 hover:text-emerald-700 transition-colors">🌻 ガーデニング</a>
              </div>
            </div>

            <!-- X アカウント -->
            <div class="mt-6 pt-6 border-t border-gray-200">
              <a href="https://x.com/plant_navi_jp" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-emerald-700 transition-colors">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                @plant_navi_jp
              </a>
            </div>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
