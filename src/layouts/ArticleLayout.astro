---
import BaseLayout from './BaseLayout.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Heading { depth: number; slug: string; text: string; }
interface RelatedPost { title: string; description: string; date: Date; tags: string[]; href: string; }

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: 'houseplant' | 'succulent' | 'gardening';
  headings?: Heading[];
  relatedPosts?: RelatedPost[];
  affiliateType?: string;
}

const { title, description, date, tags, category, headings = [], relatedPosts = [], affiliateType = 'houseplant' } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryLabelMap = {
  'houseplant': '観葉植物',
  'succulent': '多肉植物',
  'gardening': 'ガーデニング',
};
const categoryLabel = categoryLabelMap[category];
const categoryHref = `/${category}/`;

const siteUrl = 'https://plant-life-navi.com';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;

// 構造化データ用のカテゴリ名（emoji無し）
const categoryNameMap = {
  'houseplant': '観葉植物',
  'succulent': '多肉植物',
  'gardening': 'ガーデニング',
};
const categoryName = categoryNameMap[category];

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Plant Life Navi編集部',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Plant Life Navi',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.ico`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  image: `${siteUrl}/og-image.png`,
  keywords: tags.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: categoryName, item: `${siteUrl}${categoryHref}` },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};

const jsonLd = [blogPostingSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="lg:flex lg:gap-12">

      <!-- メインコンテンツ -->
      <div class="lg:flex-1 lg:min-w-0 max-w-3xl">

        <!-- パンくずリスト -->
        <nav class="text-xs text-[var(--color-ink-mute)] mb-8 flex items-center gap-2">
          <a href="/" class="hover:text-[var(--color-accent-700)] transition-colors">ホーム</a>
          <span>/</span>
          <a href={categoryHref} class="hover:text-[var(--color-accent-700)] transition-colors">{categoryLabel}</a>
        </nav>

        <h1 class="font-serif text-2xl md:text-3xl font-medium text-[var(--color-ink)] leading-tight tracking-tight mb-4">{title}</h1>

        <time datetime={date.toISOString()} class="text-xs text-[var(--color-ink-mute)] block mb-10 tabular-nums">{formattedDate}</time>

        <TableOfContents headings={headings} />

        <!-- アフィリエイトボックス（目次直後） -->
        <AffiliateBox type={affiliateType} />

        <!-- 記事本文 -->
        <article class="
          prose prose-neutral max-w-none prose-base leading-relaxed
          prose-headings:font-serif prose-headings:font-medium prose-headings:tracking-tight
          prose-p:text-[var(--color-ink-sub)] prose-p:leading-[1.95] prose-p:mb-6
          prose-h2:text-xl prose-h2:text-[var(--color-ink)] prose-h2:mt-14 prose-h2:mb-5 prose-h2:pb-3 prose-h2:border-b-2 prose-h2:border-[var(--color-accent-600)]
          prose-h3:text-lg prose-h3:text-[var(--color-ink)] prose-h3:mt-10 prose-h3:mb-3 prose-h3:pb-1.5 prose-h3:border-b prose-h3:border-[var(--color-rule)]
          prose-ul:my-5 prose-ol:my-5
          prose-li:text-[var(--color-ink-sub)] prose-li:leading-[1.85] prose-li:my-1
          prose-table:text-sm prose-th:bg-neutral-50 prose-th:text-[var(--color-ink)] prose-td:text-[var(--color-ink-sub)]
          prose-strong:text-[var(--color-ink)] prose-strong:font-medium
          prose-a:text-[var(--color-accent-700)] prose-a:no-underline hover:prose-a:underline
          prose-hr:border-[var(--color-rule)]
        ">
          <slot />
        </article>

        <!-- アフィリエイトボックス（末尾） -->
        <AffiliateBox type={affiliateType} />

        <ShareButtons title={title} url={pageUrl} />

        <!-- タグ（記事末の関連キーワード） -->
        {tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-[var(--color-rule)]">
            <p class="text-xs text-[var(--color-ink-mute)] tracking-widest uppercase mb-3">Keywords</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5">
              {tags.map((tag) => (
                <span class="text-sm text-[var(--color-ink-sub)]">{tag}</span>
              ))}
            </div>
          </div>
        )}

        <div class="lg:hidden">
          <RelatedArticles posts={relatedPosts} />
        </div>

        <div class="mt-14 pt-6 border-t border-[var(--color-rule)]">
          <a href={categoryHref} class="inline-flex items-center gap-2 text-sm text-[var(--color-accent-700)] hover:text-[var(--color-accent-800)] transition-colors">
            ← {categoryLabel}の記事一覧に戻る
          </a>
        </div>
      </div>

      <!-- PC用サイドバー -->
      {relatedPosts.length > 0 && (
        <aside class="hidden lg:block lg:w-64 lg:shrink-0">
          <div class="sticky top-20">
            <p class="text-xs font-medium text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Related</p>
            <ul class="border-t border-[var(--color-rule)]">
              {relatedPosts.map((post) => (
                <li>
                  <a href={post.href} class="group block py-3 border-b border-[var(--color-rule)] transition-colors">
                    <p class="text-sm text-[var(--color-ink)] group-hover:text-[var(--color-accent-700)] transition-colors leading-snug line-clamp-3">{post.title}</p>
                  </a>
                </li>
              ))}
            </ul>

            <div class="mt-8 pt-6 border-t border-[var(--color-rule)]">
              <p class="text-xs font-medium text-[var(--color-ink-mute)] tracking-widest uppercase mb-3">Category</p>
              <div class="flex flex-col gap-2.5 text-sm">
                <a href="/houseplant/" class="text-[var(--color-ink-sub)] hover:text-[var(--color-accent-700)] transition-colors">観葉植物</a>
                <a href="/succulent/" class="text-[var(--color-ink-sub)] hover:text-[var(--color-accent-700)] transition-colors">多肉植物</a>
                <a href="/gardening/" class="text-[var(--color-ink-sub)] hover:text-[var(--color-accent-700)] transition-colors">ガーデニング</a>
              </div>
            </div>

            <div class="mt-6 pt-6 border-t border-[var(--color-rule)]">
              <a href="https://x.com/plant_navi_jp" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-sub)] hover:text-[var(--color-ink)] transition-colors">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                @plant_navi_jp
              </a>
            </div>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
