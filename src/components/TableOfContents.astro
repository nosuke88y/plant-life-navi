---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocItems.length > 0 && (
  <nav class="toc bg-gray-50 border border-gray-200 rounded-xl p-5 mb-10">
    <p class="text-sm font-bold text-gray-700 mb-3">📑 目次</p>
    <ul class="space-y-1.5">
      {tocItems.map((item) => (
        <li class={item.depth === 3 ? 'ml-4' : ''}>
          <a href={`#${item.slug}`} class="text-sm text-gray-600 hover:text-emerald-700 transition-colors leading-relaxed block">
            {item.depth === 3 ? '└ ' : ''}{item.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
