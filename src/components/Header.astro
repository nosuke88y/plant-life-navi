---
import { Menu, X } from 'lucide-astro';
const navLinks = [
  { href: '/houseplant/', label: '観葉植物' },
  { href: '/succulent/', label: '多肉植物' },
  { href: '/gardening/', label: 'ガーデニング' },
  { href: '/profile/', label: 'プロフィール' },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-[var(--color-rule)] sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-lg font-medium tracking-tight text-[var(--color-ink)] hover:text-[var(--color-accent-700)] transition-colors">
      Plant Life Navi
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-[var(--color-accent-700)] font-medium'
              : 'text-[var(--color-ink-sub)] hover:text-[var(--color-ink)]'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-10 h-10 text-[var(--color-ink-sub)] hover:text-[var(--color-ink)] transition-colors"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <span id="icon-open"><Menu size={22} strokeWidth={1.5} /></span>
      <span id="icon-close" class="hidden"><X size={22} strokeWidth={1.5} /></span>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-rule)] bg-white">
    <div class="max-w-4xl mx-auto px-4 py-2 flex flex-col">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-2 py-3 text-sm border-b border-[var(--color-rule)] last:border-b-0 transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-[var(--color-accent-700)] font-medium'
              : 'text-[var(--color-ink-sub)] hover:text-[var(--color-ink)]'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
