---
const navLinks = [
  { href: '/houseplant/', label: '🌿 観葉植物' },
  { href: '/succulent/', label: '🪴 多肉植物' },
  { href: '/gardening/', label: '🌻 ガーデニング' },
  { href: '/profile/', label: 'プロフィール' },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-emerald-700 hover:text-emerald-600 transition-colors">
      <span class="text-2xl">🌿</span>
      <span>Plant Life Navi</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'bg-emerald-100 text-emerald-700'
              : 'text-gray-600 hover:bg-gray-100'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-md text-gray-600 hover:bg-gray-100 transition-colors"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <div class="max-w-4xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-4 py-2.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'bg-emerald-100 text-emerald-700'
              : 'text-gray-600 hover:bg-gray-100'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
