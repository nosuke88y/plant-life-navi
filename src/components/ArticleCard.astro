---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
  'data-themes'?: string;
}

const { title, description, date, tags, href, 'data-themes': themes } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class="article-card group block py-6 pl-4 -ml-4 border-b border-[var(--color-rule)] border-l-2 border-l-transparent hover:border-l-[var(--color-accent-600)] transition-colors"
  data-tags={tags.join(',')}
  data-themes={themes || ''}
>
  <time datetime={date.toISOString()} class="block text-xs text-[var(--color-ink-mute)] tabular-nums mb-1.5">
    {formattedDate}
  </time>
  <h2 class="text-base md:text-lg font-medium text-[var(--color-accent-700)] group-hover:underline underline-offset-4 decoration-[var(--color-accent-600)]/40 leading-snug mb-1.5">
    {title}
  </h2>
  <p class="text-sm text-[var(--color-ink-sub)] line-clamp-2 leading-relaxed">{description}</p>
</a>
