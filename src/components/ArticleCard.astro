---
import { ChevronRight } from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
  'data-themes'?: string;
}

const { title, description, date, tags, href, 'data-themes': themes } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class="article-card group block py-6 pl-4 -ml-4 border-b border-[var(--color-rule)] border-l-2 border-l-transparent hover:border-l-[var(--color-accent-600)] transition-colors"
  data-tags={tags.join(',')}
  data-themes={themes || ''}
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <time datetime={date.toISOString()} class="block text-xs text-[var(--color-ink-mute)] tabular-nums mb-1.5">
        {formattedDate}
      </time>
      <h2 class="text-base md:text-lg font-medium text-[var(--color-accent-700)] underline underline-offset-4 decoration-[var(--color-accent-600)]/40 group-hover:decoration-[var(--color-accent-600)] leading-snug mb-1.5">
        {title}
      </h2>
      <p class="text-sm text-[var(--color-ink-sub)] line-clamp-2 leading-relaxed">{description}</p>
    </div>
    <ChevronRight size={18} strokeWidth={1.5} class="shrink-0 mt-6 text-[var(--color-ink-mute)] group-hover:text-[var(--color-accent-700)] group-hover:translate-x-0.5 transition-all" />
  </div>
</a>
