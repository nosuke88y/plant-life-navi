---
interface RelatedPost {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-16 pt-8 border-t border-[var(--color-rule)]">
    <h2 class="text-sm font-medium text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Related</h2>
    <ul class="border-t border-[var(--color-rule)]">
      {posts.map((post) => (
        <li>
          <a href={post.href} class="group block py-4 border-b border-[var(--color-rule)] transition-colors hover:bg-neutral-50 px-2 -mx-2">
            <p class="text-sm text-[var(--color-ink)] group-hover:text-[var(--color-accent-700)] transition-colors leading-snug">
              {post.title}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
