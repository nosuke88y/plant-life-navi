---
import { ArrowRight } from 'lucide-astro';

interface Link {
  href: string;
  text: string;
  img: string;
}

interface Props {
  type: string;
}

const { type } = Astro.props;

const andPlants: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+EB00LE+4W8G+5YJRM',
  text: 'パーソナル診断で自分に合う観葉植物が見つかるオンラインストア「AND PLANTS」',
  img: 'https://www10.a8.net/0.gif?a8mat=4AZQGO+EB00LE+4W8G+5YJRM',
};
const flowerSubscription: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+EAEKZM+4W8G+BWVTE',
  text: 'お花の定期便 by アンドプランツ',
  img: 'https://www19.a8.net/0.gif?a8mat=4AZQGO+EAEKZM+4W8G+BWVTE',
};
const primaOnline: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+EGCX1E+4UD8+61RIA',
  text: '造花・フェイクグリーン専門店プリマオンライン',
  img: 'https://www16.a8.net/0.gif?a8mat=4AZQGO+EGCX1E+4UD8+61RIA',
};
const organicFertilizer: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+E6TZCY+5TR4+5YRHE',
  text: 'はじめてのオーガニック肥料に最適「生きてる肥料」',
  img: 'https://www15.a8.net/0.gif?a8mat=4AZQGO+E6TZCY+5TR4+5YRHE',
};
const premierGarden: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGP+85IRK2+28UK+61JSI',
  text: '喜ばれる贈り物「PREMIER GARDEN」',
  img: 'https://www19.a8.net/0.gif?a8mat=4AZQGP+85IRK2+28UK+61JSI',
};
const hitoHana: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+EDDR0I+3GBU+NTJWY',
  text: 'HitoHana お花の定期便',
  img: 'https://www13.a8.net/0.gif?a8mat=4AZQGO+EDDR0I+3GBU+NTJWY',
};
const tasHana: Link = {
  href: 'https://px.a8.net/svt/ejp?a8mat=4AZQGO+E97PS2+4XOY+5YJRM',
  text: '花の定期便（タスハナ）',
  img: 'https://www13.a8.net/0.gif?a8mat=4AZQGO+E97PS2+4XOY+5YJRM',
};

const linksMap: Record<string, Link[]> = {
  'houseplant': [andPlants],
  'houseplant-prima': [andPlants, primaOnline],
  'succulent': [andPlants],
  'succulent-prima': [andPlants, primaOnline],
  'gardening-flowers': [flowerSubscription],
  'gardening-flowers-full': [flowerSubscription, premierGarden, hitoHana, tasHana],
  'gardening-soil': [organicFertilizer],
  'gardening-general': [andPlants],
};

const links = linksMap[type] || [andPlants];
---

<aside class="not-prose my-8">
  <p class="text-[0.7rem] tracking-[0.2em] uppercase text-[var(--color-ink-mute)] font-medium mb-3">おすすめアイテム</p>
  <ul class="flex flex-col gap-3">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          rel="nofollow sponsored"
          class="group flex items-center gap-3 px-4 py-3.5 border-2 border-[var(--color-accent-600)] rounded-sm bg-white hover:bg-[var(--color-accent-700)] transition-colors"
        >
          <div class="flex-1 min-w-0">
            <p class="text-sm md:text-[0.95rem] font-bold leading-snug text-[var(--color-accent-700)] group-hover:text-white transition-colors">{link.text}</p>
            <p class="text-[0.7rem] text-[var(--color-ink-mute)] group-hover:text-white/80 mt-1 transition-colors">公式サイトで詳細を見る</p>
          </div>
          <ArrowRight size={18} strokeWidth={2} class="shrink-0 text-[var(--color-accent-700)] group-hover:text-white group-hover:translate-x-0.5 transition-all" />
          <img border="0" width="1" height="1" src={link.img} alt="" class="sr-only" />
        </a>
      </li>
    ))}
  </ul>
</aside>
